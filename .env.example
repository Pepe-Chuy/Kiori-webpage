# Variables de entorno de Kiori (kiori_spec.md §15). Copiar a .env.local.
# Todas pendientes de recibir credenciales del cliente [PENDIENTE].

# --- Base de datos ---
MONGODB_URI=

# --- NextAuth / Auth.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Envía.com ---
ENVIA_API_KEY=

# --- Email (Resend o SendGrid) ---
EMAIL_API_KEY=
